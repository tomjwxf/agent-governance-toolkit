    "agent",
    "governance",
    "trust",
    "identity",
    "policy",
    "audit"
  ],
  "author": "Microsoft Corporation",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/microsoft/agent-governance-toolkit.git",
    "directory": "packages/agent-mesh/sdks/typescript"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "@types/jest": "^29.5.0",
    "eslint": "^8.56.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "rimraf": "^5.0.0"
  },
  "dependencies": {
    "js-yaml": "^4.1.0",
    "@noble/ed25519": "^2.0.0"
  },
  "engines": {
